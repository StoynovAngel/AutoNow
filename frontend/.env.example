GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Mapbox public token (starts with "pk."). Get one at https://account.mapbox.com/access-tokens/
# This is a CLIENT token — it ships in the app bundle. Lock it down in the Mapbox dashboard
# with URL/bundle restrictions and a $0 spend cap rather than relying on secrecy.
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your-token-here
